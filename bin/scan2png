#!/usr/bin/env bash
# Scan image to PNG with Brother DCP-7060D scanner
# Files to /mnt/syno/scans/ with AI-powered filing and date-based last resort
# Usage: scan2png

set -e

SCAN_DIR="/mnt/syno/scans"
AI_SCRIPT="scan2png"
source "$HOME/arch/bin/ai-provider"

# Verify output directory
if [ ! -d "$SCAN_DIR" ]; then
    echo "Error: Output directory $SCAN_DIR does not exist. Is /mnt/syno mounted?"
    exit 1
fi

# Detect Brother scanner
echo "Detecting scanner..."
scanner_device=$(scanimage -L 2>&1 | grep "brother4:" | sed -n "s/device \`\([^']*\)'.*/\1/p" | head -1)

if [ -z "$scanner_device" ]; then
    echo "Error: Brother scanner not found. Is it powered on and connected?"
    exit 1
fi

echo "Using scanner: $scanner_device"
echo "Resolution: 300 DPI (Color)"
echo "Output: $SCAN_DIR/<folder>/<filename>.png"
echo ""

# Scan to temp PNG
echo "Scanning..."
tmp_png=$(mktemp /tmp/scan-XXXXXX.png)

scanimage --device-name "$scanner_device" \
    --format=png \
    --resolution 300 \
    --mode "24bit Color" \
    > "$tmp_png"

# Auto-crop scanner bed using Claude vision
echo "Cropping..."
img_dims=$(magick identify -format '%wx%h' "$tmp_png")
img_w=${img_dims%x*}
img_h=${img_dims#*x}
crop_pcts=$("$HOME/arch/bin/scan-crop" "$tmp_png" 2>/dev/null || true)

if [ -n "$crop_pcts" ]; then
    IFS=',' read -r left top right bottom <<< "$crop_pcts"
    cx=$(( img_w * left / 100 ))
    cy=$(( img_h * top / 100 ))
    cw=$(( img_w * (right - left) / 100 ))
    ch=$(( img_h * (bottom - top) / 100 ))
    # Sanity: cropped area must be at least 40% of original
    if [ $((cw * ch * 100 / (img_w * img_h))) -ge 40 ]; then
        magick "$tmp_png" -crop "${cw}x${ch}+${cx}+${cy}" +repage "$tmp_png"
        echo "  Cropped to ${cw}x${ch}."
    else
        echo "  Crop area too small, keeping original."
    fi
else
    echo "  Could not detect crop bounds, keeping original."
fi

# File the scan (PNG passed as both image for Ollama and file for Claude)
try_ai_file "$tmp_png" "$tmp_png"

# Save
mkdir -p "$suggested_folder"
output_path="$suggested_folder/${suggested_file}.png"
mv "$tmp_png" "$output_path"

if [ -f "$output_path" ]; then
    file_size=$(du -h "$output_path" | cut -f1)
    echo "Saved: $output_path ($file_size)"
else
    echo "Error: Scan failed"
fi
