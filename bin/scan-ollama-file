#!/usr/bin/env python3
"""Single-pass document filing via Ollama vision model.

Takes a scanned image, sends it directly to a vision model with structured
JSON output, and returns a folder + filename. No intermediate text description
step - the vision model does classification and naming in one pass.

Usage:
    scan-ollama-file /path/to/scanned.tiff [/path/to/ocr-text.txt]
    scan-ollama-file /path/to/scanned.png [/path/to/ocr-text.txt]

Output (two lines):
    /mnt/syno/scans/folder-name
    filename-without-extension

Exit code 1 if filing fails (caller falls back to next method).
"""

import base64
import importlib.machinery
import importlib.util
import json
import os
import re
import sys
import unicodedata
import urllib.request

SCAN_DIR = "/mnt/syno/scans"
OLLAMA_MODEL = "qwen3-vl:4b"
OLLAMA_URL = "http://localhost:11434/api/generate"


def gather_folder_context() -> str:
    """Build a description of existing folders and their files."""
    if not os.path.isdir(SCAN_DIR):
        return "The scans directory does not exist yet."

    entries = sorted(os.listdir(SCAN_DIR))
    folders = []
    for entry in entries:
        full = os.path.join(SCAN_DIR, entry)
        if not os.path.isdir(full):
            continue
        files = []
        for item in sorted(os.listdir(full)):
            item_path = os.path.join(full, item)
            if os.path.isfile(item_path):
                files.append(item)
            elif os.path.isdir(item_path):
                try:
                    for sub in sorted(os.listdir(item_path))[:5]:
                        if os.path.isfile(os.path.join(item_path, sub)):
                            files.append(f"{item}/{sub}")
                except PermissionError:
                    pass
        folders.append((entry, files[:20]))

    if not folders:
        return "The scans directory is currently empty (no folders yet)."

    lines = ["Existing folders in the scans directory:"]
    for name, files in folders:
        if files:
            lines.append(f"  {name}/")
            for f in files[:10]:
                lines.append(f"    {f}")
        else:
            lines.append(f"  {name}/ (empty)")
    return "\n".join(lines)


def sanitize(text: str) -> str:
    """Clean a string into a valid lowercase hyphenated name."""
    text = text.strip().strip('`"\' /\\')
    text = text.split("\n")[-1].strip()
    text = re.sub(r"\.(pdf|png|jpg|jpeg|tiff?)$", "", text, flags=re.IGNORECASE)
    text = unicodedata.normalize("NFKD", text).encode("ascii", "ignore").decode("ascii")
    text = re.sub(r"[^a-z0-9\-]", "", text.lower())
    text = re.sub(r"-+", "-", text).strip("-")
    return text


def deduplicate(target_dir: str, base_name: str, ext: str) -> str:
    """Ensure filename doesn't collide with existing files."""
    final = base_name
    counter = 1
    while os.path.exists(os.path.join(target_dir, f"{final}.{ext}")):
        counter += 1
        final = f"{base_name}-{counter}"
    return final


def main():
    if len(sys.argv) < 2:
        print("Usage: scan-ollama-file <image-path>", file=sys.stderr)
        sys.exit(1)

    image_path = sys.argv[1]
    if not os.path.isfile(image_path):
        print(f"File not found: {image_path}", file=sys.stderr)
        sys.exit(1)

    ext = os.path.splitext(image_path)[1].lstrip(".").lower() or "pdf"

    # Check ollama is reachable
    try:
        urllib.request.urlopen("http://localhost:11434/api/tags", timeout=3)
    except Exception:
        print("Ollama not reachable", file=sys.stderr)
        sys.exit(1)

    img_b64 = base64.b64encode(open(image_path, "rb").read()).decode("ascii")
    folder_context = gather_folder_context()

    # Load OCR text if provided
    ocr_text = ""
    if len(sys.argv) >= 3 and os.path.isfile(sys.argv[2]):
        ocr_text = open(sys.argv[2]).read().strip()
        # Truncate to avoid huge payloads
        ocr_text = "\n".join(ocr_text.splitlines()[:40])

    ocr_section = ""
    if ocr_text:
        ocr_section = f"""
OCR text extracted from this document (use this for typed/printed text like names, dates, addresses, clinic names):
{ocr_text}
"""

    prompt = f"""You are a document filing assistant. Analyze this scanned document image and decide a folder name and filename.

Folder rules:
- Lowercase, hyphens between words
- Broad categories: municipal-taxes, insurance, banking, medical, receipts, correspondence, utilities, legal, employment, photos
- If an existing folder clearly relates to this document, REUSE it
- NEVER use generic names like "misc", "other", "documents"

Filename rules:
- All lowercase, hyphens only (no underscores, no spaces)
- Format: DATE-SOURCE-DESCRIPTION
- DATE comes first (YYYY-MM-DD, or YYYY-MM if only month visible, or YYYY if only year)
- SOURCE: company, clinic, organization, or person who issued the document
- DESCRIPTION: document type + key details. Include the specialty or subject (e.g. urology, dentist, home, auto). Include dollar amounts for receipts/invoices (e.g. 85-50 for $85.50)
- Do NOT include the patient or account holder name in the filename - the owner already knows it is theirs
- Do NOT repeat the folder name in the filename (folder already provides the category)
- Do NOT include the file extension
- Keep it concise but specific - aim for under 80 characters
- NEVER suggest a filename identical to one already in the folder
- Do NOT attempt to read handwritten text for the filename. Only use printed/typed text.
{ocr_section}
{folder_context}

Reply in EXACTLY this format (two lines, nothing else):
FOLDER: folder-name
FILE: filename-without-extension"""

    payload = {
        "model": OLLAMA_MODEL,
        "prompt": prompt,
        "images": [img_b64],
        "stream": False,
        "options": {"temperature": 0, "think": False},
    }

    req = urllib.request.Request(
        OLLAMA_URL,
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json; charset=utf-8"},
    )
    resp = urllib.request.urlopen(req, timeout=120)
    data = json.loads(resp.read().decode("utf-8"))

    raw = data.get("response", "")

    folder_name = None
    file_name = None
    for line in raw.splitlines():
        line = line.strip()
        upper = line.upper()
        if upper.startswith("FOLDER:"):
            folder_name = sanitize(line.split(":", 1)[1])
        elif upper.startswith("FILE:"):
            file_name = sanitize(line.split(":", 1)[1])

    if not folder_name or len(folder_name) < 2:
        folder_name = "unsorted"
    if not file_name or len(file_name) < 3:
        print("Ollama returned unusable filename", file=sys.stderr)
        sys.exit(1)

    target_dir = os.path.join(SCAN_DIR, folder_name)

    # Fuzzy-match folder and filename against existing files
    fuzzy_path = os.path.join(os.path.dirname(__file__), "scan-fuzzy-match")
    loader = importlib.machinery.SourceFileLoader("scan_fuzzy", fuzzy_path)
    spec = importlib.util.spec_from_file_location("scan_fuzzy", fuzzy_path, loader=loader)
    fuzzy_mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(fuzzy_mod)

    folder_name = fuzzy_mod.fuzzy_correct_folder(folder_name, SCAN_DIR)
    folder_name = fuzzy_mod.year_subfolder(folder_name, file_name)
    target_dir = os.path.join(SCAN_DIR, folder_name)
    file_name = fuzzy_mod.fuzzy_correct(file_name, target_dir)

    final_name = deduplicate(target_dir, file_name, ext)

    print(target_dir)
    print(final_name)


if __name__ == "__main__":
    main()
