#!/bin/bash
# Set up bwbio (Bitwarden CLI with desktop app IPC unlock)
# Requires: npm, bitwarden-desktop, polkit
set -euo pipefail

# Install bwbio from npm (uses ~/.local prefix)
npm config set prefix ~/.local
npm install -g bitwarden-cli-bio
echo "bwbio installed"

# Create symlink for socket path compatibility
# Newer Bitwarden versions use "app.bitwarden", bwbio expects "s.bw"
SOCKET_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/com.bitwarden.desktop"
if [ -S "$SOCKET_DIR/app.bitwarden" ] && [ ! -e "$SOCKET_DIR/s.bw" ]; then
    ln -s "$SOCKET_DIR/app.bitwarden" "$SOCKET_DIR/s.bw"
    echo "Socket symlink created"
fi

# Install polkit rule to bypass password prompt for Bitwarden IPC unlock
RULE="/etc/polkit-1/rules.d/90-bitwarden-nopasswd.rules"
if [ ! -f "$RULE" ]; then
    echo "Creating polkit rule (requires sudo)..."
    sudo tee "$RULE" > /dev/null << 'POLKIT'
polkit.addRule(function(action, subject) {
    if (action.id == "com.bitwarden.Bitwarden.unlock" &&
        subject.user == "nicholas") {
        return polkit.Result.YES;
    }
});
POLKIT
    echo "Polkit rule installed"
fi

echo "Done. Run 'bwbio unlock' with the desktop app running and unlocked."
