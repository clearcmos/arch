#!/usr/bin/env python3
"""List dialog with double-click activation. Prints selected tag to stdout.

Usage: qt-menu "Title" tag1 "Label 1" tag2 "Label 2" ...
  Tags are returned on stdout. Labels are displayed.
  Double-click or select + Enter to choose. Close/Escape to cancel (exit 1).
"""
import sys

from PyQt6.QtCore import Qt
from PyQt6.QtWidgets import QApplication, QDialog, QListWidget, QVBoxLayout


class MenuDialog(QDialog):
    def __init__(self, title, items):
        super().__init__()
        self.setWindowTitle(title)
        self.selected_tag = None
        self.items = items

        self.list = QListWidget()
        for tag, label in items:
            self.list.addItem(label)
        self.list.itemDoubleClicked.connect(self._on_double_click)
        self.list.setCurrentRow(0)

        layout = QVBoxLayout()
        layout.addWidget(self.list)
        self.setLayout(layout)
        self.resize(380, 200)

    def _on_double_click(self, item):
        row = self.list.row(item)
        self.selected_tag = self.items[row][0]
        self.accept()

    def keyPressEvent(self, event):
        if event.key() in (Qt.Key.Key_Return, Qt.Key.Key_Enter):
            row = self.list.currentRow()
            if row >= 0:
                self.selected_tag = self.items[row][0]
                self.accept()
        else:
            super().keyPressEvent(event)


def main():
    if len(sys.argv) < 4 or (len(sys.argv) - 2) % 2 != 0:
        print(f"Usage: {sys.argv[0]} \"Title\" tag1 \"Label 1\" tag2 \"Label 2\" ...",
              file=sys.stderr)
        sys.exit(1)

    title = sys.argv[1]
    args = sys.argv[2:]
    items = [(args[i], args[i + 1]) for i in range(0, len(args), 2)]

    app = QApplication(sys.argv[:1])
    dlg = MenuDialog(title, items)

    if dlg.exec() and dlg.selected_tag:
        print(dlg.selected_tag)
        sys.exit(0)
    sys.exit(1)


if __name__ == "__main__":
    main()
