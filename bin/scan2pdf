#!/usr/bin/env bash
# Scan document to searchable PDF with Brother DCP-7060D scanner
# Tesseract adds searchable text layer (OCR)
# Files to /mnt/syno/scans/ with AI-powered filing and date-based last resort
# Usage: scan2pdf [--append]

set -e

SCAN_DIR="/mnt/syno/scans"
APPEND_MODE=false

if [ "$1" = "--append" ]; then
    APPEND_MODE=true
fi

if [ "$APPEND_MODE" = false ]; then
    AI_SCRIPT="scan2pdf"
    source "$HOME/arch/bin/ai-provider"
fi

# Verify output directory
if [ ! -d "$SCAN_DIR" ]; then
    echo "Error: Output directory $SCAN_DIR does not exist. Is /mnt/syno mounted?"
    exit 1
fi

# Detect Brother scanner
echo "Detecting scanner..."
scanner_device=$(scanimage -L 2>&1 | grep "brother4:" | sed -n "s/device \`\([^']*\)'.*/\1/p" | head -1)

if [ -z "$scanner_device" ]; then
    echo "Error: Brother scanner not found. Is it powered on and connected?"
    exit 1
fi

echo "Using scanner: $scanner_device"
echo "Resolution: 300 DPI (Grayscale, searchable PDF with OCR)"
echo ""

# Scan to temp TIFF
echo "Scanning..."
tmp_tiff=$(mktemp /tmp/scan-XXXXXX.tiff)

scanimage --device-name "$scanner_device" \
    --format=tiff \
    --resolution 300 \
    --mode Gray \
    > "$tmp_tiff"

# OCR to searchable PDF
echo "Creating searchable PDF..."
tmp_pdf_base=$(mktemp /tmp/scan-pdf-XXXXXX)
tesseract "$tmp_tiff" "$tmp_pdf_base" -l eng+fra pdf 2>/dev/null
tmp_pdf="${tmp_pdf_base}.pdf"

if [ "$APPEND_MODE" = true ]; then
    # Append mode: select existing PDF via fzf, add new page to it
    echo ""
    echo "Select a PDF to append to:"
    target=$(find "$SCAN_DIR" -name "*.pdf" -type f | \
        sed "s|^${SCAN_DIR}/||" | \
        sort | \
        fzf --height=20 --reverse --prompt="Append to: ")

    if [ -z "$target" ]; then
        echo "No file selected. Aborting."
        rm -f "$tmp_tiff" "$tmp_pdf_base" "$tmp_pdf"
        exit 1
    fi

    target_path="$SCAN_DIR/$target"
    tmp_merged=$(mktemp /tmp/scan-merged-XXXXXX.pdf)

    # Merge existing PDF + new page
    pdfunite "$target_path" "$tmp_pdf" "$tmp_merged"
    mv "$tmp_merged" "$target_path"

    rm -f "$tmp_tiff" "$tmp_pdf_base" "$tmp_pdf"

    page_count=$(pdfinfo "$target_path" 2>/dev/null | grep "^Pages:" | awk '{print $2}')
    file_size=$(du -h "$target_path" | cut -f1)
    echo "Appended to: $target_path ($page_count pages, $file_size)"
else
    # Normal mode: AI-powered filing
    echo "Output: $SCAN_DIR/<folder>/<filename>.pdf"

    # Extract OCR text for Ollama
    tmp_ocr=$(mktemp /tmp/scan-ocr-XXXXXX)
    tesseract "$tmp_tiff" "$tmp_ocr" -l eng+fra 2>/dev/null

    # File the scan
    try_ai_file "$tmp_pdf" "$tmp_tiff" "${tmp_ocr}.txt"

    # Cleanup temp files
    rm -f "$tmp_tiff" "$tmp_pdf_base" "${tmp_ocr}.txt" "$tmp_ocr"

    # Save
    mkdir -p "$suggested_folder"
    output_path="$suggested_folder/${suggested_file}.pdf"
    mv "$tmp_pdf" "$output_path"

    if [ -f "$output_path" ]; then
        file_size=$(du -h "$output_path" | cut -f1)
        echo "Saved: $output_path ($file_size)"
    else
        echo "Error: Scan failed"
    fi
fi
