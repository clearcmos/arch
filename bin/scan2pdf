#!/usr/bin/env bash
# Scan document to searchable PDF with Brother DCP-7060D scanner
# Tesseract adds searchable text layer (OCR)
# Files to /mnt/syno/scans/ using: Claude (default) -> Ollama (fallback) -> date-based (last resort)
# Usage: scan2pdf

set -e

SCAN_DIR="/mnt/syno/scans"
CLAUDE_FILE="$HOME/arch/bin/scan-claude-file"
OLLAMA_FILE="$HOME/arch/bin/scan-ollama-file"

# Try filing with cascade: Claude -> Ollama -> local fallback
# Sets suggested_folder and suggested_file
try_filing() {
    local pdf_path="$1"
    local tiff_path="$2"
    local ocr_text_path="$3"
    suggested_folder=""
    suggested_file=""

    # 1. Try Claude (reads the PDF directly)
    echo "Filing with Claude..."
    local start_time=$SECONDS
    if result=$("$CLAUDE_FILE" "$pdf_path" 2>/dev/null); then
        suggested_folder=$(echo "$result" | sed -n '1p')
        suggested_file=$(echo "$result" | sed -n '2p')
        if [ -n "$suggested_folder" ] && [ -n "$suggested_file" ]; then
            echo "  Filed by Claude in $((SECONDS - start_time))s."
            return
        fi
    fi

    # 2. Try Ollama (single-pass vision model + OCR text)
    echo "Claude unavailable, trying Ollama..."
    if [ -n "$tiff_path" ] && [ -f "$tiff_path" ]; then
        local ollama_args=("$tiff_path")
        if [ -n "$ocr_text_path" ] && [ -f "$ocr_text_path" ]; then
            ollama_args+=("$ocr_text_path")
        fi
        local start_time=$SECONDS
        if result=$("$OLLAMA_FILE" "${ollama_args[@]}" 2>/dev/null); then
            suggested_folder=$(echo "$result" | sed -n '1p')
            suggested_file=$(echo "$result" | sed -n '2p')
            if [ -n "$suggested_folder" ] && [ -n "$suggested_file" ]; then
                echo "  Filed by Ollama in $((SECONDS - start_time))s."
                return
            fi
        fi
    fi

    # 3. Local fallback
    echo "AI unavailable. Using date-based filename."
    suggested_folder="$SCAN_DIR/unsorted"
    suggested_file="scan-$(date +%Y%m%d-%H%M%S)"
}

# Verify output directory
if [ ! -d "$SCAN_DIR" ]; then
    echo "Error: Output directory $SCAN_DIR does not exist. Is /mnt/syno mounted?"
    exit 1
fi

# Detect Brother scanner
echo "Detecting scanner..."
scanner_device=$(scanimage -L 2>&1 | grep "brother4:" | sed -n "s/device \`\([^']*\)'.*/\1/p" | head -1)

if [ -z "$scanner_device" ]; then
    echo "Error: Brother scanner not found. Is it powered on and connected?"
    exit 1
fi

echo "Using scanner: $scanner_device"
echo "Resolution: 300 DPI (Grayscale, searchable PDF with OCR)"
echo "Output: $SCAN_DIR/<folder>/<filename>.pdf"
echo ""

# Scan to temp TIFF
echo "Scanning..."
tmp_tiff=$(mktemp /tmp/scan-XXXXXX.tiff)

scanimage --device-name "$scanner_device" \
    --format=tiff \
    --resolution 300 \
    --mode Gray \
    > "$tmp_tiff"

# OCR to searchable PDF + extract text for Ollama
echo "Creating searchable PDF..."
tmp_pdf_base=$(mktemp /tmp/scan-pdf-XXXXXX)
tmp_ocr=$(mktemp /tmp/scan-ocr-XXXXXX)
tesseract "$tmp_tiff" "$tmp_pdf_base" -l eng+fra pdf 2>/dev/null
tesseract "$tmp_tiff" "$tmp_ocr" -l eng+fra 2>/dev/null
tmp_pdf="${tmp_pdf_base}.pdf"

# File the scan (pass TIFF for image, OCR text file for context)
try_filing "$tmp_pdf" "$tmp_tiff" "${tmp_ocr}.txt"

# Cleanup temp files
rm -f "$tmp_tiff" "$tmp_pdf_base" "${tmp_ocr}.txt" "$tmp_ocr"

# Save
mkdir -p "$suggested_folder"
output_path="$suggested_folder/${suggested_file}.pdf"
mv "$tmp_pdf" "$output_path"

if [ -f "$output_path" ]; then
    file_size=$(du -h "$output_path" | cut -f1)
    echo "Saved: $output_path ($file_size)"
else
    echo "Error: Scan failed"
fi
