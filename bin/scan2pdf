#!/usr/bin/env bash
# Scan document to searchable PDF with Brother DCP-7060D scanner
# Tesseract adds searchable text layer (OCR)
# Files to /mnt/syno/scans/ using: Claude (default) -> Ollama (fallback) -> date-based (last resort)
# Usage: scan2pdf

set -e

SCAN_DIR="/mnt/syno/scans"
CLAUDE_FILE="$HOME/arch/bin/scan-claude-file"
SMART_FILE="$HOME/arch/bin/scan-smart-file"
VISION_MODEL="qwen2.5vl:7b"
OLLAMA_URL="http://localhost:11434/api/generate"

# Get a text description of a document image using vision model
describe_document() {
    local image_path="$1"

    if ! curl -s --max-time 2 http://localhost:11434/api/tags > /dev/null 2>&1; then
        return 1
    fi

    local img_b64
    img_b64=$(base64 -w0 "$image_path")

    local payload_file
    payload_file=$(mktemp /tmp/scan-ollama-XXXXXX.json)

    python3 -c "
import json, sys
payload = {
    'model': '$VISION_MODEL',
    'prompt': 'What type of document is this? Include: the document type, any company or organization name, any dates or years visible, and the language. Be specific and concise, one paragraph.',
    'images': [sys.stdin.read().strip()],
    'stream': False
}
json.dump(payload, open('$payload_file', 'w'))
" <<< "$img_b64"

    local response
    response=$(curl -s --max-time 120 "$OLLAMA_URL" -d @"$payload_file" 2>/dev/null)
    rm -f "$payload_file"

    echo "$response" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    desc = data.get('response', '').strip()
    if len(desc) > 5:
        print(desc)
except:
    pass
" 2>/dev/null
}

# Try filing with cascade: Claude -> Ollama -> local fallback
# Sets suggested_folder and suggested_file
try_filing() {
    local pdf_path="$1"
    local tiff_path="$2"
    suggested_folder=""
    suggested_file=""

    # 1. Try Claude (reads the PDF directly)
    echo "Filing with Claude..."
    if result=$("$CLAUDE_FILE" "$pdf_path" 2>/dev/null); then
        suggested_folder=$(echo "$result" | sed -n '1p')
        suggested_file=$(echo "$result" | sed -n '2p')
        if [ -n "$suggested_folder" ] && [ -n "$suggested_file" ]; then
            echo "  Filed by Claude."
            return
        fi
    fi

    # 2. Try Ollama (vision model on TIFF + text model for filing)
    echo "Claude unavailable, trying Ollama..."
    if [ -n "$tiff_path" ] && [ -f "$tiff_path" ]; then
        local description=""
        description=$(describe_document "$tiff_path" 2>/dev/null) || true
        if [ -n "$description" ]; then
            if result=$(echo "$description" | python3 "$SMART_FILE" pdf 2>/dev/null); then
                suggested_folder=$(echo "$result" | sed -n '1p')
                suggested_file=$(echo "$result" | sed -n '2p')
                if [ -n "$suggested_folder" ] && [ -n "$suggested_file" ]; then
                    echo "  Filed by Ollama."
                    return
                fi
            fi
        fi
    fi

    # 3. Local fallback
    echo "AI unavailable. Using date-based filename."
    suggested_folder="$SCAN_DIR/unsorted"
    suggested_file="scan-$(date +%Y%m%d-%H%M%S)"
}

# Verify output directory
if [ ! -d "$SCAN_DIR" ]; then
    echo "Error: Output directory $SCAN_DIR does not exist. Is /mnt/syno mounted?"
    exit 1
fi

# Detect Brother scanner
echo "Detecting scanner..."
scanner_device=$(scanimage -L 2>&1 | grep "brother4:" | sed -n "s/device \`\([^']*\)'.*/\1/p" | head -1)

if [ -z "$scanner_device" ]; then
    echo "Error: Brother scanner not found. Is it powered on and connected?"
    exit 1
fi

echo "Using scanner: $scanner_device"
echo "Resolution: 300 DPI (Grayscale, searchable PDF with OCR)"
echo "Output: $SCAN_DIR/<folder>/<filename>.pdf"
echo ""

# Scan to temp TIFF
echo "Scanning..."
tmp_tiff=$(mktemp /tmp/scan-XXXXXX.tiff)

scanimage --device-name "$scanner_device" \
    --format=tiff \
    --resolution 300 \
    --mode Gray \
    > "$tmp_tiff"

# OCR to searchable PDF
echo "Creating searchable PDF..."
tmp_pdf_base=$(mktemp /tmp/scan-pdf-XXXXXX)
tesseract "$tmp_tiff" "$tmp_pdf_base" -l eng+fra pdf 2>/dev/null
tmp_pdf="${tmp_pdf_base}.pdf"

# File the scan (pass both PDF and TIFF so Ollama can use the image)
try_filing "$tmp_pdf" "$tmp_tiff"

# Cleanup temp files
rm -f "$tmp_tiff" "$tmp_pdf_base"

# Save
mkdir -p "$suggested_folder"
output_path="$suggested_folder/${suggested_file}.pdf"
mv "$tmp_pdf" "$output_path"

if [ -f "$output_path" ]; then
    file_size=$(du -h "$output_path" | cut -f1)
    echo "Saved: $output_path ($file_size)"
else
    echo "Error: Scan failed"
fi
