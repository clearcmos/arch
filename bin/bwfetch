#!/bin/bash
# Fetch fields from a Bitwarden item by name (case-insensitive exact match)
# Usage: bwfetch                  - browse entire vault, pick item then field
#        bwfetch <name>           - interactive fzf field picker, copies to clipboard
#        bwfetch <name> <field>   - prints value to stdout (for scripting)
set -euo pipefail

BW_API="http://127.0.0.1:8087"
name="${1:-}"
field="${2:-}"

# Ensure bw serve is running
if ! curl -sf "$BW_API/status" &>/dev/null; then
    echo "Starting bw-serve..." >&2
    systemctl --user start bw-serve.service
    # Wait for it to come up
    for i in $(seq 1 20); do
        curl -sf "$BW_API/status" &>/dev/null && break
        sleep 0.25
    done
    if ! curl -sf "$BW_API/status" &>/dev/null; then
        echo "Failed to start bw-serve" >&2
        exit 1
    fi
fi

bw_api() {
    curl -sf "$BW_API/$1"
}

if [ -z "$name" ]; then
    # Browse mode - list all vault items, pick one, then pick a field
    all_items=$(bw_api "list/object/items" | jq '.data.data')
    if [ -z "$all_items" ] || [ "$(echo "$all_items" | jq 'length')" -eq 0 ]; then
        echo "Vault is empty or locked" >&2
        exit 1
    fi

    # fzf over item names (deduplicated display, but pass index for lookup)
    selected_name=$(echo "$all_items" | jq -r '.[].name' | sort -fu | fzf \
        --height=~30 \
        --layout=reverse \
        --no-multi \
        --header="Select item (ESC to cancel)" \
    ) || exit 0

    # Re-exec with the selected name
    exec "$0" "$selected_name"
fi

# Get all items matching the search term, then filter for exact name match (case-insensitive)
items=$(bw_api "list/object/items?search=$name" | jq -r --arg name "$name" '
    [.data.data[] | select(.name | ascii_downcase == ($name | ascii_downcase))]
')

count=$(echo "$items" | jq 'length')

if [ "$count" -eq 0 ]; then
    echo "No items found matching \"$name\"" >&2
    exit 1
fi

# Build field list from all matching items
# Format: "field_name\tvalue" (tab-separated)
fields=$(echo "$items" | jq -r '
    .[] | .name as $item |
    (
        (if .login.username // "" | length > 0 then ["\($item) > username\t\(.login.username)"] else [] end) +
        (if .login.password // "" | length > 0 then ["\($item) > password\t\(.login.password)"] else [] end) +
        (if .login.totp // "" | length > 0 then ["\($item) > totp\t\(.login.totp)"] else [] end) +
        (if (.login.uris // [] | length) > 0 then [.login.uris[] | "\($item) > uri\t\(.uri)"] else [] end) +
        (if .notes // "" | length > 0 then ["\($item) > notes\t\(.notes)"] else [] end) +
        (if (.fields // [] | length) > 0 then [.fields[] | "\($item) > \(.name)\t\(.value)"] else [] end)
    ) | .[]
')

if [ -z "$fields" ]; then
    echo "No fields found for \"$name\"" >&2
    exit 1
fi

# Direct field lookup - print value to stdout and exit
if [ -n "$field" ]; then
    value=$(echo "$fields" | awk -F'\t' -v f="$field" '
        tolower($1) ~ " > " tolower(f) "$" { print $2; found=1; exit }
        END { if (!found) exit 1 }
    ')
    if [ $? -ne 0 ]; then
        echo "Field \"$field\" not found" >&2
        exit 1
    fi
    if [ -t 1 ]; then
        echo "$value"
    else
        echo -n "$value"
    fi
    exit 0
fi

# Interactive mode - fzf picker, copies to clipboard
selected=$(echo "$fields" | fzf \
    --with-nth=1 \
    --delimiter=$'\t' \
    --height=~20 \
    --layout=reverse \
    --no-multi \
    --header="Select field (ESC to cancel)" \
    --bind='one:accept' \
)

if [ -n "$selected" ]; then
    value=$(echo "$selected" | cut -f2)
    echo -n "$value" | wl-copy
    field_name=$(echo "$selected" | cut -f1)
    echo "Copied: $field_name"
fi
