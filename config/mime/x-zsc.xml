<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-zsc">
    <comment>zsc encrypted archive</comment>
    <magic priority="60">
      <match type="string" offset="0" value="ZSC\x01"/>
    </magic>
    <glob pattern="*.zsc"/>
    <sub-class-of type="application/octet-stream"/>
  </mime-type>
</mime-info>
