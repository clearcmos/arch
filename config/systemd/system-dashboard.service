[Unit]
Description=System Dashboard - Real-time monitoring
After=network.target

[Service]
Type=simple
ExecStart=/home/nicholas/git/system-dashboard/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8200
WorkingDirectory=/home/nicholas/git/system-dashboard/backend
Restart=always
RestartSec=5
User=root
Group=root
Environment=PYTHONUNBUFFERED=1

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true

[Install]
WantedBy=multi-user.target
