<?xml version="1.0"?>
<labwc_config>

  <core>
    <gap>8</gap>
  </core>

  <!-- Theme and title bars -->
  <theme>
    <name>CatppuccinMocha</name>
    <cornerRadius>8</cornerRadius>
    <titlebar>
      <layout>icon:iconify,max,close</layout>
    </titlebar>
    <font name="Sans" size="12" />
  </theme>

  <!-- Window behavior -->
  <focus>
    <followMouse>no</followMouse>
    <raiseOnFocus>yes</raiseOnFocus>
  </focus>

  <placement>
    <policy>center</policy>
  </placement>

  <!-- Keyboard bindings -->
  <keyboard>
    <default />

    <!-- Window management -->
    <keybind key="W-q"><action name="Close" /></keybind>
    <keybind key="W-F"><action name="ToggleFullscreen" /></keybind>

    <!-- Maximize (toggle) -->
    <keybind key="W-Up"><action name="ToggleMaximize" direction="both" /></keybind>

    <!-- Snap left/right -->
    <keybind key="W-Left"><action name="SnapToEdge" direction="left" /></keybind>
    <keybind key="W-Right"><action name="SnapToEdge" direction="right" /></keybind>

    <!-- Launch apps -->
    <keybind key="W-Return"><action name="Execute" command="ghostty" /></keybind>
    <keybind key="W-space"><action name="Execute" command="rofi -show drun" /></keybind>
    <keybind key="W-e"><action name="Execute" command="thunar" /></keybind>

    <!-- Alt+Tab window switching -->
    <keybind key="A-Tab"><action name="NextWindow" /></keybind>
    <keybind key="A-S-Tab"><action name="PreviousWindow" /></keybind>

    <!-- Workspaces -->
    <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
    <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
    <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
    <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>
    <keybind key="W-5"><action name="GoToDesktop" to="5" /></keybind>
    <keybind key="W-6"><action name="GoToDesktop" to="6" /></keybind>
    <keybind key="W-7"><action name="GoToDesktop" to="7" /></keybind>
    <keybind key="W-8"><action name="GoToDesktop" to="8" /></keybind>
    <keybind key="W-9"><action name="GoToDesktop" to="9" /></keybind>

    <keybind key="W-S-1"><action name="SendToDesktop" to="1" follow="false" /></keybind>
    <keybind key="W-S-2"><action name="SendToDesktop" to="2" follow="false" /></keybind>
    <keybind key="W-S-3"><action name="SendToDesktop" to="3" follow="false" /></keybind>
    <keybind key="W-S-4"><action name="SendToDesktop" to="4" follow="false" /></keybind>
    <keybind key="W-S-5"><action name="SendToDesktop" to="5" follow="false" /></keybind>
    <keybind key="W-S-6"><action name="SendToDesktop" to="6" follow="false" /></keybind>
    <keybind key="W-S-7"><action name="SendToDesktop" to="7" follow="false" /></keybind>
    <keybind key="W-S-8"><action name="SendToDesktop" to="8" follow="false" /></keybind>
    <keybind key="W-S-9"><action name="SendToDesktop" to="9" follow="false" /></keybind>

    <!-- Screenshots -->
    <keybind key="Print"><action name="Execute" command='grim -g "$(slurp)" - | wl-copy' /></keybind>
    <keybind key="S-Print"><action name="Execute" command="grim - | wl-copy" /></keybind>

    <!-- Volume -->
    <keybind key="XF86AudioRaiseVolume"><action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+" /></keybind>
    <keybind key="XF86AudioLowerVolume"><action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-" /></keybind>
    <keybind key="XF86AudioMute"><action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" /></keybind>

    <!-- Exit session -->
    <keybind key="W-m"><action name="Exit" /></keybind>
  </keyboard>

  <!-- Mouse bindings -->
  <mouse>
    <default />
  </mouse>

  <!-- Desktops/Workspaces -->
  <desktops number="9" />

  <!-- Window rules: all new windows open maximized -->
  <windowRules>
    <windowRule identifier="*">
      <action name="Maximize" />
    </windowRule>
    <windowRule identifier="brave-browser" serverDecoration="yes" />
    <windowRule identifier="google-chrome" serverDecoration="yes" />
  </windowRules>

</labwc_config>
