#!/bin/bash

# Set monitors: Left (portrait) | Center (landscape) | Right (portrait)
# labwc uses wlr-output-management, configure via kanshi or wlr-randr
wlr-randr \
    --output HDMI-A-1 --mode 2560x1440 --pos 0,0 --scale 1.5 --transform 90 \
    --output DP-2 --mode 2560x1440 --pos 960,0 --scale 1.5 \
    --output DP-1 --mode 2560x1440 --pos 2667,0 --scale 1.5 --transform 90 \
    &

# Panel (bottom, center monitor only)
waybar &

# Notifications
mako &

# Polkit agent
/usr/lib/polkit-kde-authentication-agent-1 &

# Bluetooth - connect trusted devices
(sleep 3 && bluetoothctl connect E8:EE:CC:46:F1:AC) &

# GTK theme
gsettings set org.gnome.desktop.interface gtk-theme 'catppuccin-mocha-blue-standard+default'
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
gsettings set org.gnome.desktop.interface icon-theme 'breeze-dark'
